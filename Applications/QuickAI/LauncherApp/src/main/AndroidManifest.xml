<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- QuickAIService runs an embedded REST server on 127.0.0.1:3453.
         INTERNET is required to bind a listening socket even on loopback. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Foreground service API + the "dataSync" category we run as. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>

    <!-- Android 13+ requires runtime permission to post notifications,
         which the foreground service needs for its ongoing notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuickAI">

        <!--
          LiteRT-LM GPU backend needs access to these Android system native
          libraries. Marked required="false" so the app still installs on
          devices that do not expose them — the LiteRtLmBackend falls back
          to CPU in that case. See how-to-use-litert-lm-guide.md §2.
        -->
        <uses-native-library
            android:name="libvndksupport.so"
            android:required="false"/>
        <uses-native-library
            android:name="libOpenCL.so"
            android:required="false"/>

        <!--
          QuickAIService runs in a dedicated ":remote" process and is
          exported=true so the single service instance can be started /
          hosted by LauncherApp and then contacted by arbitrary ClientApps
          over the loopback REST endpoint.
        -->
        <service
            android:name=".QuickAIService"
            android:enabled="true"
            android:exported="true"
            android:process=":remote"
            android:foregroundServiceType="dataSync"
            tools:ignore="ExportedService" />

        <activity
            android:name=".LauncherApp"
            android:exported="true"
            android:theme="@style/Theme.QuickAI">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
