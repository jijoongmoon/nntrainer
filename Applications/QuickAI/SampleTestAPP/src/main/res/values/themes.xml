<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      SampleTestAPP's MainActivity extends AppCompatActivity and builds
      its UI entirely in code (no XML layouts). The only reason this
      theme has to exist is that AndroidManifest.xml's <application
      android:theme="@style/Theme.SampleTestAPP"> points at it — every
      AppCompat activity needs an AppCompat-derived theme at
      inflation time, otherwise AppCompatDelegate throws
      "You need to use a Theme.AppCompat theme (or descendant)…".

      Using DayNight.DarkActionBar mirrors what Android Studio's
      "Empty Views Activity" wizard scaffolds and matches the style
      used by sibling module :clientapp for consistency.
    -->
    <style name="Theme.SampleTestAPP" parent="Theme.AppCompat.DayNight.DarkActionBar" />
</resources>
