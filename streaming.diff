+/* SPDX-License-Identifier: Apache-2.0
+ * Copyright (C) 2026 Samsung Electronics Co., Ltd. All Rights Reserved.
+ *
+ * @file    callback_streamer.h
+ * @date    28 Mar 2026
+ * @brief   Callback-based streamer for JNI integration
+ *          Bridges C++ generation to Java/Kotlin callbacks
+ */
+
+#ifndef __CALLBACK_STREAMER_H__
+#define __CALLBACK_STREAMER_H__
+
+#include "streamer.h"
+#include <stdlib.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * @brief Callback function type for token streaming
+ * @param text Generated text chunk
+ * @param is_end 1 if generation is complete, 0 if ongoing
+ * @param user_data User-defined context (e.g., JNI environment)
+ */
+typedef void (*TokenCallback)(const char* text, int is_end, void* user_data);
+
+/**
+ * @brief Callback streamer structure
+ *        Extends BaseStreamer for JNI callback integration
+ */
+typedef struct {
+    BaseStreamer base;           /**< Must be first member for inheritance */
+    TokenCallback callback;      /**< User-provided callback function */
+    char* buffer;                /**< Internal buffer for partial tokens */
+    size_t buffer_size;          /**< Current buffer size */
+    size_t buffer_capacity;      /**< Buffer capacity */
+} CallbackStreamer;
+
+/**
+ * @brief Initialize callback streamer
+ * @param streamer Streamer instance to initialize
+ * @param callback Token callback function
+ * @param user_data User context data (passed to callback)
+ * @return 0 on success, -1 on failure
+ */
+int callback_streamer_init(CallbackStreamer* streamer,
+                           TokenCallback callback,
+                           void* user_data);
+
+/**
+ * @brief Cleanup callback streamer resources
+ * @param streamer Streamer instance to cleanup
+ */
+void callback_streamer_cleanup(CallbackStreamer* streamer);
+
+/**
+ * @brief Create callback streamer with dynamic allocation
+ * @param callback Token callback function
+ * @param user_data User context data
+ * @return Allocated streamer instance, NULL on failure
+ */
+CallbackStreamer* callback_streamer_create(TokenCallback callback,
+                                           void* user_data);
+
+/**
+ * @brief Destroy dynamically allocated callback streamer
+ * @param streamer Streamer instance to destroy
+ */
+void callback_streamer_destroy(CallbackStreamer* streamer);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* __CALLBACK_STREAMER_H__ */
diff --git a/Applications/CausalLM/api/causal_lm_api.cpp b/Applications/CausalLM/api/causal_lm_api.cpp
index f4069b0b1..8ee034a08 100644
--- a/Applications/CausalLM/api/causal_lm_api.cpp
+++ b/Applications/CausalLM/api/causal_lm_api.cpp
@@ -11,6 +11,7 @@
  */
 
 #include "causal_lm_api.h"
+#include "callback_streamer.h"
 #include <algorithm>
 #include <cstring>
 #include <iostream>
@@ -592,3 +593,96 @@ ErrorCode getPerformanceMetrics(PerformanceMetrics *metrics) {
 
   return CAUSAL_LM_ERROR_NONE;
 }
+
+ErrorCode runModelStreaming(const char *inputTextPrompt,
+                            StreamCallback callback,
+                            void *user_data) {
+  if (!g_initialized || !g_model) {
+    return CAUSAL_LM_ERROR_NOT_INITIALIZED;
+  }
+  if (inputTextPrompt == nullptr) {
+    return CAUSAL_LM_ERROR_INVALID_PARAMETER;
+  }
+
+  try {
+    std::lock_guard<std::mutex> lock(g_mutex);
+
+    auto causal_lm_model = dynamic_cast<causallm::CausalLM *>(g_model.get());
+    if (!causal_lm_model) {
+      return CAUSAL_LM_ERROR_UNKNOWN;
+    }
+
+    CallbackStreamer *streamer = nullptr;
+    if (callback != nullptr) {
+      streamer = callback_streamer_create(callback, user_data);
+      if (streamer == nullptr) {
+        return CAUSAL_LM_ERROR_UNKNOWN;
+      }
+      causal_lm_model->setStreamer(&streamer->base);
+    }
+
+    std::string input(inputTextPrompt);
+    if (g_use_chat_template) {
+      input = apply_chat_template(g_architecture, input);
+    }
+
+    causal_lm_model->run(input, false, "", "", g_verbose);
+
+    if (streamer != nullptr) {
+      causal_lm_model->setStreamer(nullptr);
+      callback_streamer_destroy(streamer);
+    }
+
+  } catch (const std::exception &e) {
+    std::cerr << "Exception in runModelStreaming: " << e.what() << std::endl;
+    return CAUSAL_LM_ERROR_INFERENCE_FAILED;
+  } catch (...) {
+    std::cerr << "Unknown exception in runModelStreaming" << std::endl;
+    return CAUSAL_LM_ERROR_INFERENCE_FAILED;
+  }
+
+  return CAUSAL_LM_ERROR_NONE;
+}
+
+ErrorCode runModelWithStreamer(const char *inputTextPrompt,
+                                BaseStreamer *streamer) {
+  if (!g_initialized || !g_model) {
+    return CAUSAL_LM_ERROR_NOT_INITIALIZED;
+  }
+  if (inputTextPrompt == nullptr) {
+    return CAUSAL_LM_ERROR_INVALID_PARAMETER;
+  }
+
+  try {
+    std::lock_guard<std::mutex> lock(g_mutex);
+
+    auto causal_lm_model = dynamic_cast<causallm::CausalLM *>(g_model.get());
+    if (!causal_lm_model) {
+      return CAUSAL_LM_ERROR_UNKNOWN;
+    }
+
+    // Set the streamer directly
+    if (streamer != nullptr) {
+      causal_lm_model->setStreamer(streamer);
+    }
+
+    std::string input(inputTextPrompt);
+    if (g_use_chat_template) {
+      input = apply_chat_template(g_architecture, input);
+    }
+
+    causal_lm_model->run(input, false, "", "", g_verbose);
+
+    // Reset streamer after run
+    causal_lm_model->setStreamer(nullptr);
+
+  } catch (const std::exception &e) {
+    std::cerr << "Exception in runModelWithStreamer: " << e.what() << std::endl;
+    return CAUSAL_LM_ERROR_INFERENCE_FAILED;
+  } catch (...) {
+    std::cerr << "Unknown exception in runModelWithStreamer" << std::endl;
+    return CAUSAL_LM_ERROR_INFERENCE_FAILED;
+  }
+
+  return CAUSAL_LM_ERROR_NONE;
+}
