diff --git a/Applications/CausalLM/api/buffered_streamer.cpp b/Applications/CausalLM/api/buffered_streamer.cpp
new file mode 100644
index 000000000..4d94a7e33
--- /dev/null
+++ b/Applications/CausalLM/api/buffered_streamer.cpp
@@ -0,0 +1,251 @@
+// SPDX-License-Identifier: Apache-2.0
+/**
+ * Copyright (C) 2026 Samsung Electronics Co., Ltd. All Rights Reserved.
+ *
+ * @file   buffered_streamer.cpp
+ * @date   30 Mar 2026
+ * @brief  Thread-safe buffered streamer implementation
+ *         Producer-Consumer pattern for LLM streaming
+ */
+
+#include "buffered_streamer.h"
+#include <stdlib.h>
+#include <string.h>
+
+static void buffered_put(void* self,
+                         const unsigned int* token_ids,
+                         int count,
+                         const char* text) {
+    (void)token_ids;
+    (void)count;
+    
+    BufferedStreamer* streamer = (BufferedStreamer*)self;
+    if (streamer == NULL || text == NULL) {
+        return;
+    }
+
+    // Create new node
+    BufferNode* node = (BufferNode*)malloc(sizeof(BufferNode));
+    if (node == NULL) {
+        return;
+    }
+
+    node->text = strdup(text);
+    if (node->text == NULL) {
+        free(node);
+        return;
+    }
+    node->next = NULL;
+
+    // Lock and add to queue
+    pthread_mutex_lock(&streamer->mutex);
+    
+    if (streamer->tail == NULL) {
+        // Empty queue
+        streamer->head = node;
+        streamer->tail = node;
+    } else {
+        // Append to tail
+        streamer->tail->next = node;
+        streamer->tail = node;
+    }
+    
+    // Signal waiting consumer
+    pthread_cond_signal(&streamer->cond);
+    pthread_mutex_unlock(&streamer->mutex);
+}
+
+static void buffered_end(void* self) {
+    BufferedStreamer* streamer = (BufferedStreamer*)self;
+    if (streamer == NULL) {
+        return;
+    }
+
+    pthread_mutex_lock(&streamer->mutex);
+    streamer->is_done = true;
+    // Signal all waiting consumers
+    pthread_cond_broadcast(&streamer->cond);
+    pthread_mutex_unlock(&streamer->mutex);
+}
+
+static StreamerVtbl buffered_vtbl = {
+    .put = buffered_put,
+    .end = buffered_end
+};
+
+int buffered_streamer_init(BufferedStreamer* streamer) {
+    if (streamer == NULL) {
+        return -1;
+    }
+
+    // Initialize base streamer
+    base_streamer_init(&streamer->base, &buffered_vtbl, NULL);
+    
+    // Initialize queue
+    streamer->head = NULL;
+    streamer->tail = NULL;
+    
+    // Initialize state
+    streamer->is_done = false;
+    streamer->is_initialized = true;
+
+    // Initialize synchronization primitives
+    if (pthread_mutex_init(&streamer->mutex, NULL) != 0) {
+        return -1;
+    }
+    
+    if (pthread_cond_init(&streamer->cond, NULL) != 0) {
+        pthread_mutex_destroy(&streamer->mutex);
+        return -1;
+    }
+
+    return 0;
+}
+
+void buffered_streamer_cleanup(BufferedStreamer* streamer) {
+    if (streamer == NULL || !streamer->is_initialized) {
+        return;
+    }
+
+    // Free all remaining nodes in queue
+    pthread_mutex_lock(&streamer->mutex);
+    BufferNode* node = streamer->head;
+    while (node != NULL) {
+        BufferNode* next = node->next;
+        free(node->text);
+        free(node);
+        node = next;
+    }
+    streamer->head = NULL;
+    streamer->tail = NULL;
+    pthread_mutex_unlock(&streamer->mutex);
+
+    // Destroy synchronization primitives
+    pthread_cond_destroy(&streamer->cond);
+    pthread_mutex_destroy(&streamer->mutex);
+
+    streamer->is_initialized = false;
+}
+
+BufferedStreamer* buffered_streamer_create(void) {
+    BufferedStreamer* streamer = (BufferedStreamer*)malloc(sizeof(BufferedStreamer));
+    if (streamer == NULL) {
+        return NULL;
+    }
+
+    if (buffered_streamer_init(streamer) != 0) {
+        free(streamer);
+        return NULL;
+    }
+
+    return streamer;
+}
+
+void buffered_streamer_destroy(BufferedStreamer* streamer) {
+    if (streamer == NULL) {
+        return;
+    }
+
+    buffered_streamer_cleanup(streamer);
+    free(streamer);
+}
+
+int buffered_streamer_get(BufferedStreamer* streamer, char** text_out) {
+    if (streamer == NULL || text_out == NULL || !streamer->is_initialized) {
+        return -1;
+    }
+
+    pthread_mutex_lock(&streamer->mutex);
+
+    // Wait until data available or stream ends
+    while (streamer->head == NULL && !streamer->is_done) {
+        pthread_cond_wait(&streamer->cond, &streamer->mutex);
+    }
+
+    // Check if we have data
+    if (streamer->head == NULL) {
+        // No data and stream is done
+        pthread_mutex_unlock(&streamer->mutex);
+        return 0;
+    }
+
+    // Dequeue node
+    BufferNode* node = streamer->head;
+    streamer->head = node->next;
+    if (streamer->head == NULL) {
+        streamer->tail = NULL;
+    }
+
+    pthread_mutex_unlock(&streamer->mutex);
+
+    // Return text (caller must free)
+    *text_out = node->text;
+    free(node);
+
+    return 1;
+}
+
+int buffered_streamer_has_data(BufferedStreamer* streamer) {
+    if (streamer == NULL || !streamer->is_initialized) {
+        return -1;
+    }
+
+    pthread_mutex_lock(&streamer->mutex);
+    int has_data = (streamer->head != NULL) ? 1 : 0;
+    int is_done = streamer->is_done;
+    pthread_mutex_unlock(&streamer->mutex);
+
+    if (is_done && !has_data) {
+        return -1;  // Stream ended
+    }
+    return has_data;
+}
+
+bool buffered_streamer_is_done(BufferedStreamer* streamer) {
+    if (streamer == NULL || !streamer->is_initialized) {
+        return true;
+    }
+
+    pthread_mutex_lock(&streamer->mutex);
+    bool done = streamer->is_done;
+    pthread_mutex_unlock(&streamer->mutex);
+
+    return done;
+}
+
+int buffered_streamer_wait_done(BufferedStreamer* streamer, int timeout_ms) {
+    if (streamer == NULL || !streamer->is_initialized) {
+        return -1;
+    }
+
+    pthread_mutex_lock(&streamer->mutex);
+
+    if (streamer->is_done) {
+        pthread_mutex_unlock(&streamer->mutex);
+        return 0;
+    }
+
+    int result = 0;
+    if (timeout_ms > 0) {
+        struct timespec ts;
+        clock_gettime(CLOCK_REALTIME, &ts);
+        ts.tv_sec += timeout_ms / 1000;
+        ts.tv_nsec += (timeout_ms % 1000) * 1000000;
+        if (ts.tv_nsec >= 1000000000) {
+            ts.tv_sec++;
+            ts.tv_nsec -= 1000000000;
+        }
+        
+        while (!streamer->is_done && result == 0) {
+            result = pthread_cond_timedwait(&streamer->cond, &streamer->mutex, &ts);
+        }
+    } else {
+        while (!streamer->is_done) {
+            pthread_cond_wait(&streamer->cond, &streamer->mutex);
+        }
+    }
+
+    pthread_mutex_unlock(&streamer->mutex);
+    
+    return (result == 0) ? 0 : -1;
+}
