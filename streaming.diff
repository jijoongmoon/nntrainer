@@ -0,0 +1,43 @@
+/* SPDX-License-Identifier: Apache-2.0
+ * Copyright (C) 2026 Samsung Electronics Co., Ltd. All Rights Reserved.
+ *
+ * @file    streamer.c
+ * @date    28 Mar 2026
+ * @brief   Streamer interface implementation
+ */
+
+#include "streamer.h"
+
+void base_streamer_init(BaseStreamer* streamer,
+                        const StreamerVtbl* vtbl,
+                        void* user_data) {
+    if (streamer == NULL) {
+        return;
+    }
+    streamer->vtbl = vtbl;
+    streamer->user_data = user_data;
+}
+
+void streamer_put(BaseStreamer* streamer,
+                  const unsigned int* token_ids,
+                  int count,
+                  const char* text) {
+    if (streamer == NULL || streamer->vtbl == NULL || streamer->vtbl->put == NULL) {
+        return;
+    }
+    streamer->vtbl->put(streamer, token_ids, count, text);
+}
+
+void streamer_end(BaseStreamer* streamer) {
+    if (streamer == NULL || streamer->vtbl == NULL || streamer->vtbl->end == NULL) {
+        return;
+    }
+    streamer->vtbl->end(streamer);
+}
+
+bool streamer_is_valid(BaseStreamer* streamer) {
+    return streamer != NULL &&
+           streamer->vtbl != NULL &&
+           streamer->vtbl->put != NULL &&
+           streamer->vtbl->end != NULL;
+}
diff --git a/Applications/CausalLM/api/streamer.h b/Applications/CausalLM/api/streamer.h
new file mode 100644
index 000000000..9e9450e5a
--- /dev/null
+++ b/Applications/CausalLM/api/streamer.h
@@ -0,0 +1,105 @@
+/* SPDX-License-Identifier: Apache-2.0
+ * Copyright (C) 2026 Samsung Electronics Co., Ltd. All Rights Reserved.
+ *
+ * @file    streamer.h
+ * @date    28 Mar 2026
+ * @brief   Streamer interface for real-time token generation
+ *          Similar to HuggingFace Transformers' BaseStreamer
+ * @see     https://github.com/huggingface/transformers
+ */
+
+#ifndef __STREAMER_H__
+#define __STREAMER_H__
+
+#include <stddef.h>
+#include <stdbool.h>
+
+/* API export macros */
+#ifdef _WIN32
+  #ifdef CAUSALLM_BUILDING_DLL
+    #define CAUSALLM_API __declspec(dllexport)
+  #else
+    #define CAUSALLM_API __declspec(dllimport)
+  #endif
+#else
+  #define CAUSALLM_API __attribute__((visibility("default")))
+#endif
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * @brief Streamer virtual function table (vtable)
+ *        C++ virtual function emulation in C
+ *        Similar to HuggingFace's BaseStreamer interface
+ */
+typedef struct StreamerVtbl {
+    /**
+     * @brief Called when new tokens are generated
+     * @param self Streamer instance
+     * @param token_ids Array of generated token IDs
+     * @param count Number of tokens
+     * @param text Decoded text representation
+     */
+    void (*put)(void* self,
+                const unsigned int* token_ids,
+                int count,
+                const char* text);
+
+    /**
+     * @brief Called when generation is complete
+     * @param self Streamer instance
+     */
+    void (*end)(void* self);
+} StreamerVtbl;
+
+/**
+ * @brief Base streamer structure
+ *        Must be first member of any concrete streamer implementation
+ */
+typedef struct BaseStreamer {
+    const StreamerVtbl* vtbl;  /**< Virtual function table */
+    void* user_data;           /**< User-defined context data */
+} BaseStreamer;
+
+/**
+ * @brief Initialize base streamer
+ * @param streamer Streamer instance to initialize
+ * @param vtbl Virtual function table for concrete implementation
+ * @param user_data User context data
+ */
+CAUSALLM_API void base_streamer_init(BaseStreamer* streamer,
+                         const StreamerVtbl* vtbl,
+                         void* user_data);
+
+/**
+ * @brief Put tokens to streamer
+ * @param streamer Streamer instance
+ * @param token_ids Token IDs array
+ * @param count Number of tokens
+ * @param text Decoded text
+ */
+CAUSALLM_API void streamer_put(BaseStreamer* streamer,
+                  const unsigned int* token_ids,
+                  int count,
+                  const char* text);
+
+/**
+ * @brief Signal end of generation
+ * @param streamer Streamer instance
+ */
+CAUSALLM_API void streamer_end(BaseStreamer* streamer);
+
+/**
+ * @brief Check if streamer is valid (non-null with valid vtbl)
+ * @param streamer Streamer instance
+ * @return true if valid, false otherwise
+ */
+CAUSALLM_API bool streamer_is_valid(BaseStreamer* streamer);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* __STREAMER_H__ */
