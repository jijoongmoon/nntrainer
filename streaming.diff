+/* SPDX-License-Identifier: Apache-2.0
+ * Copyright (C) 2026 Samsung Electronics Co., Ltd. All Rights Reserved.
+ *
+ * @file    callback_streamer.c
+ * @date    28 Mar 2026
+ * @brief   Callback streamer implementation
+ */
+
+#include "callback_streamer.h"
+#include <string.h>
+
+#define INITIAL_BUFFER_CAPACITY 256
+
+static void callback_put(void* self,
+                         const unsigned int* token_ids,
+                         int count,
+                         const char* text) {
+    CallbackStreamer* streamer = (CallbackStreamer*)self;
+    if (streamer == NULL || streamer->callback == NULL || text == NULL) {
+        return;
+    }
+
+    streamer->callback(text, 0, streamer->base.user_data);
+}
+
+static void callback_end(void* self) {
+    CallbackStreamer* streamer = (CallbackStreamer*)self;
+    if (streamer == NULL || streamer->callback == NULL) {
+        return;
+    }
+
+    streamer->callback("", 1, streamer->base.user_data);
+}
+
+static StreamerVtbl callback_vtbl = {
+    .put = callback_put,
+    .end = callback_end
+};
+
+int callback_streamer_init(CallbackStreamer* streamer,
+                           TokenCallback callback,
+                           void* user_data) {
+    if (streamer == NULL || callback == NULL) {
+        return -1;
+    }
+
+    base_streamer_init(&streamer->base, &callback_vtbl, user_data);
+    streamer->callback = callback;
+    streamer->buffer = NULL;
+    streamer->buffer_size = 0;
+    streamer->buffer_capacity = 0;
+
+    return 0;
+}
+
+void callback_streamer_cleanup(CallbackStreamer* streamer) {
+    if (streamer == NULL) {
+        return;
+    }
+
+    if (streamer->buffer != NULL) {
+        free(streamer->buffer);
+        streamer->buffer = NULL;
+    }
+    streamer->buffer_size = 0;
+    streamer->buffer_capacity = 0;
+    streamer->callback = NULL;
+}
+
+CallbackStreamer* callback_streamer_create(TokenCallback callback,
+                                           void* user_data) {
+    if (callback == NULL) {
+        return NULL;
+    }
+
+    CallbackStreamer* streamer = (CallbackStreamer*)malloc(sizeof(CallbackStreamer));
+    if (streamer == NULL) {
+        return NULL;
+    }
+
+    if (callback_streamer_init(streamer, callback, user_data) != 0) {
+        free(streamer);
+        return NULL;
+    }
+
+    return streamer;
+}
+
+void callback_streamer_destroy(CallbackStreamer* streamer) {
+    if (streamer == NULL) {
+        return;
+    }
+
+    callback_streamer_cleanup(streamer);
+    free(streamer);
+}
