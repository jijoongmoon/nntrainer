@@ -0,0 +1,111 @@
+// SPDX-License-Identifier: Apache-2.0
+/**
+ * Copyright (C) 2026 Samsung Electronics Co., Ltd. All Rights Reserved.
+ *
+ * @file   buffered_streamer.h
+ * @date   30 Mar 2026
+ * @brief  Thread-safe buffered streamer with get() interface
+ *         Producer-Consumer pattern for LLM streaming
+ */
+
+#ifndef __BUFFERED_STREAMER_H__
+#define __BUFFERED_STREAMER_H__
+
+#include "streamer.h"
+#include <pthread.h>
+#include <stdbool.h>
+#include <stddef.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * @brief Buffer node for linked list queue
+ */
+typedef struct BufferNode {
+    char* text;
+    struct BufferNode* next;
+} BufferNode;
+
+/**
+ * @brief Thread-safe buffered streamer
+ *        Producer (LLM thread) puts tokens via vtbl->put()
+ *        Consumer (user thread) gets tokens via buffered_streamer_get()
+ */
+typedef struct {
+    BaseStreamer base;           /**< Must be first member */
+    
+    // Thread-safe queue
+    BufferNode* head;            /**< Queue head (for get) */
+    BufferNode* tail;            /**< Queue tail (for put) */
+    pthread_mutex_t mutex;       /**< Queue mutex */
+    pthread_cond_t cond;         /**< Condition variable */
+    
+    // State
+    bool is_done;                /**< Generation complete flag */
+    bool is_initialized;         /**< Initialization flag */
+} BufferedStreamer;
+
+/**
+ * @brief Initialize buffered streamer
+ * @param streamer Streamer instance to initialize
+ * @return 0 on success, -1 on failure
+ */
+CAUSALLM_API int buffered_streamer_init(BufferedStreamer* streamer);
+
+/**
+ * @brief Cleanup buffered streamer resources
+ * @param streamer Streamer instance to cleanup
+ */
+CAUSALLM_API void buffered_streamer_cleanup(BufferedStreamer* streamer);
+
+/**
+ * @brief Create buffered streamer with dynamic allocation
+ * @return Allocated streamer instance, NULL on failure
+ */
+CAUSALLM_API BufferedStreamer* buffered_streamer_create(void);
+
+/**
+ * @brief Destroy dynamically allocated buffered streamer
+ * @param streamer Streamer instance to destroy
+ */
+CAUSALLM_API void buffered_streamer_destroy(BufferedStreamer* streamer);
+
+/**
+ * @brief Get text from buffer (blocking)
+ *        Consumer thread calls this to get tokens
+ * @param streamer Streamer instance
+ * @param text_out Output buffer to store text (must be freed by caller)
+ * @return 1 if got data, 0 if stream ended and no more data, -1 on error
+ * @note Blocks until data available or stream ends
+ */
+CAUSALLM_API int buffered_streamer_get(BufferedStreamer* streamer, char** text_out);
+
+/**
+ * @brief Non-blocking check if data is available
+ * @param streamer Streamer instance
+ * @return 1 if data available, 0 if not, -1 if stream ended
+ */
+CAUSALLM_API int buffered_streamer_has_data(BufferedStreamer* streamer);
+
+/**
+ * @brief Check if stream has ended
+ * @param streamer Streamer instance
+ * @return true if stream ended, false otherwise
+ */
+CAUSALLM_API bool buffered_streamer_is_done(BufferedStreamer* streamer);
+
+/**
+ * @brief Wait for stream to complete
+ * @param streamer Streamer instance
+ * @param timeout_ms Timeout in milliseconds (0 for no timeout)
+ * @return 0 on success, -1 on timeout
+ */
+CAUSALLM_API int buffered_streamer_wait_done(BufferedStreamer* streamer, int timeout_ms);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* __BUFFERED_STREAMER_H__ */
